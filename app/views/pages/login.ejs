<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Entrar | Conexão por Crédito</title>
  <link rel="icon" href="../img/logo-black.png">
  <link rel="stylesheet" href="../css/login.css" />
  <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
  <script src="https://kit.fontawesome.com/a81368914c.js" crossorigin="anonymous"></script>
</head>

<body>

<section class="container" id="container">

  <!-- ================= LOGIN ================= -->
  <section class="form-container sign-in-container">
    <form action="/login" method="POST">

      <h1>Login</h1>

      <% if (erro) { %>
        <p class="msg-erro"><%= erro %></p>
      <% } %>

      <input 
        type="text" 
        name="usuarioDigitado" 
        placeholder="Usuário"
        value="<%= valores?.usuarioDigitado || '' %>"
        class="<%= erroValidacao?.usuarioDigitado ? 'input-error' : (valores?.usuarioDigitado ? 'input-success' : '') %>">

      <% if (msgErro?.usuarioDigitado) { %>
        <p class="msg-erro"><%= msgErro.usuarioDigitado %></p>
      <% } %>

      <input 
        type="password" 
        name="senhaDigitada" 
        placeholder="Senha"
        class="<%= erroValidacao?.senhaDigitada ? 'input-error' : '' %>">

      <% if (msgErro?.senhaDigitada) { %>
        <p class="msg-erro"><%= msgErro.senhaDigitada %></p>
      <% } %>

      <a href="#">Esqueceu a senha?</a>

      <button type="submit">Entrar</button>

      <p>ou entre com</p>

      <section class="social-container">
        <a href="#" class="social"><i class="bx bxl-google"></i></a>
        <a href="#" class="social"><i class="bx bxl-facebook"></i></a>
        <a href="#" class="social"><i class="bx bxl-github"></i></a>
        <a href="#" class="social"><i class="bx bxl-linkedin"></i></a>
      </section>

      <section class="mobile-toggle">
        <p>Não tem conta?</p>
        <button type="button" class="ghost" id="mobileSignUp">Cadastrar</button>
      </section>

    </form>
  </section>

  <!-- ================= CADASTRO ================= -->
  <section class="form-container sign-up-container">
    <form action="/cadastro" method="POST">

      <h1>Cadastro</h1>

      <% if (sucesso) { %>
        <p class="msg-sucesso"><%= sucesso %></p>
      <% } %>

      <!-- NOME -->
      <input 
        type="text" 
        name="nome" 
        placeholder="Usuário"
        value="<%= valores?.nome || '' %>"
        class="<%= erroValidacao?.nome ? 'input-error' : (valores?.nome ? 'input-success' : '') %>">

      <% if (msgErro?.nome) { %>
        <p class="msg-erro"><%= msgErro.nome %></p>
      <% } %>

      <!-- EMAIL -->
      <input 
        type="email" 
        name="email" 
        placeholder="Email"
        value="<%= valores?.email || '' %>"
        class="<%= erroValidacao?.email ? 'input-error' : (valores?.email ? 'input-success' : '') %>">

      <% if (msgErro?.email) { %>
        <p class="msg-erro"><%= msgErro.email %></p>
      <% } %>

      <!-- SENHA -->
      <input 
        type="password" 
        name="senha" 
        placeholder="Senha"
        class="<%= erroValidacao?.senha ? 'input-error' : '' %>">

      <% if (msgErro?.senha) { %>
        <p class="msg-erro"><%= msgErro.senha %></p>
      <% } %>

      <!-- CONFIRMAR SENHA -->
      <input 
        type="password" 
        name="confirmarSenha" 
        placeholder="Confirmar senha"
        class="<%= erroValidacao?.confirmarSenha ? 'input-error' : '' %>">

      <% if (msgErro?.confirmarSenha) { %>
        <p class="msg-erro"><%= msgErro.confirmarSenha %></p>
      <% } %>

      <button type="submit">Cadastrar</button>

      <p>ou cadastre-se com</p>

      <section class="social-container">
        <a href="#" class="social"><i class="bx bxl-google"></i></a>
        <a href="#" class="social"><i class="bx bxl-facebook"></i></a>
        <a href="#" class="social"><i class="bx bxl-github"></i></a>
        <a href="#" class="social"><i class="bx bxl-linkedin"></i></a>
      </section>

      <section class="mobile-toggle">
        <p>Já tem uma conta?</p>
        <button type="button" class="ghost" id="mobileSignIn">Login</button>
      </section>

    </form>
  </section>

  <!-- ================= OVERLAY ================= -->
  <section class="overlay-container">
    <section class="overlay">

      <section class="overlay-panel overlay-left">
        <section class="logo">
          <img src="/img/logo-white.png" alt="CPC Logo">
        </section>

        <h1>Bem-vindo de volta!</h1>
        <p>Já tem uma conta? Entre e continue conosco.</p>

        <button class="ghost" id="signIn">Login</button>
      </section>

      <section class="overlay-panel overlay-right">
        <section class="logo">
          <img src="/img/logo-white.png" alt="CPC Logo">
        </section>

        <h1>Olá, seja bem-vindo!</h1>
        <p>Não tem uma conta? Crie uma agora mesmo.</p>

        <button class="ghost" id="signUp">Cadastrar</button>
      </section>

    </section>
  </section>

</section>

<script src="../js/login.js"></script>

</body>
</html>