<link rel="icon" href="../img/logo-black.png">
<link rel="stylesheet" href="../css/header.css">              
<header class="main-header">
    <section class="header-container">
 
        <!-- LOGIN MOBILE -->
        <% if (!usuarioLogado) { %>
            <a href="/login" class="login mobile-login">LOGIN</a>
        <% } else { %>
            <a href="/conta" class="login mobile-login"><img src="/img/img perfil-white.png" alt="Perfil" class="perfil-img"></a>
        <% } %>

        <!-- LOGO -->
        <section class="logo">
            <a href="/">
                <img src="/img/logo-white.png" alt="CPC Logo">
            </a>
        </section>
 
        <!-- MENU DESKTOP -->
        <nav class="desktop-menu">
            <ul>
                <li><a href="/">INÍCIO</a></li>
                <li><a href="/sobrenos">SOBRE NÓS</a></li>
                <li><a href="/comofunciona">COMO FUNCIONA</a></li>
                <li><a href="/servicos">SERVIÇOS DE TROCA</a></li>
                <li><a href="/saibamais">SAIBA MAIS</a></li>
                <li><a href="/noticia">NOTÍCIAS</a></li>
            </ul>
        </nav>
 
        <!-- AÇÕES DESKTOP -->
        <section class="desktop-actions">
            <% if (!usuarioLogado) { %>
                <a href="/login" class="login">LOGIN</a>
            <% } else { %>
                <a href="/conta" class="perfil-icon" title="Meu Perfil"><img src="/img/img perfil-white.png" alt="Perfil" class="perfil-img"></a>
            <% } %>
        </section>
 
        <!-- HAMBURGER MOBILE -->
        <section class="hamburger mobile-menu" id="hamburger">
            <span></span>
            <span></span>
            <span></span>
        </section>
 
    </section>
</header>
 
<script src="/js/menu.js"></script>
 
<!-- OVERLAY -->
<section class="overlay" id="overlay"></section>
 
<!-- MENU LATERAL MOBILE -->
<nav class="side-menu" id="sideMenu">
    <ul>
        <li><a href="/">INÍCIO</a></li>
        <li><a href="/sobrenos">SOBRE NÓS</a></li>
        <li><a href="/comofunciona">COMO FUNCIONA</a></li>
        <li><a href="/servicos">SERVIÇOS DE TROCA</a></li>
        <li><a href="/saibamais">SAIBA MAIS</a></li>
        <li><a href="/noticia">NOTÍCIAS</a></li>
        <% if (usuarioLogado) { %>
            <li><a href="/conta">MINHA CONTA</a></li>
            <li><a href="/logout">SAIR</a></li>
        <% } %>
    </ul>
</nav>
